---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import EmailCapture from "../components/EmailCapture.astro";
import Pillar from "../components/Pillar.astro";
import { getContentBySlugs } from "../lib/supabase";

const blocks = await getContentBySlugs([
  "hero",
  "story",
  "pillar-sourced",
  "pillar-roasted",
  "pillar-shipped",
]);

const hero = blocks["hero"] ?? {
  title: "Coffee, in its truest meridian.",
  body: "A small roastery pursuing clarity in every cup. Single-origin, small-batch, shipped the week it's roasted.",
  seo_description: null,
};

const story = blocks["story"] ?? {
  title: "Our story",
  body: "Meridian began as three friends chasing one cup — the one that tasted like the place it came from. We source small lots from growers we know by name, roast light to let origin speak, and ship within seven days of roast. No blends, no mystery, no marketing gloss. Just coffee that tells the truth.",
};

const pillars = [
  { idx: "01 / origin", block: blocks["pillar-sourced"] },
  { idx: "02 / craft", block: blocks["pillar-roasted"] },
  { idx: "03 / cup", block: blocks["pillar-shipped"] },
].map(({ idx, block }) => ({
  idx,
  title: block?.title ?? "",
  body: block?.body ?? "",
}));

const description =
  hero.seo_description ??
  "Meridian is a specialty coffee roastery launching soon. Single-origin, small-batch, shipped fresh. Join the list for first access.";
---
<Base title="Meridian — Specialty Coffee, Coming Soon" description={description}>
  <ThemeToggle />

  <header class="relative z-10 mx-auto flex w-full max-w-7xl items-center justify-between px-6 pt-6 md:px-10">
    <a href="/" class="flex items-center gap-2 font-[family-name:var(--font-display)] text-xl italic">
      <span class="inline-block h-2 w-2 rounded-full bg-[color:var(--color-copper)]"></span>
      meridian
    </a>
    <nav class="hidden items-center gap-8 text-xs uppercase tracking-[0.28em] text-[color:var(--color-mist)] md:flex">
      <a href="#story" class="transition hover:text-[color:var(--color-copper)]">Story</a>
      <a href="#craft" class="transition hover:text-[color:var(--color-copper)]">Craft</a>
      <a href="#notify" class="transition hover:text-[color:var(--color-copper)]">Notify me</a>
    </nav>
  </header>

  <section class="relative z-10 mx-auto flex min-h-[86vh] w-full max-w-7xl flex-col items-center justify-center px-6 py-24 text-center md:px-10">
    <p class="mb-6 inline-flex items-center gap-3 text-[10px] uppercase tracking-[0.42em] text-[color:var(--color-mist)]">
      <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[color:var(--color-copper)]"></span>
      Launching · Spring Release
    </p>
    <h1 class="font-[family-name:var(--font-display)] text-[13vw] font-light leading-[0.9] tracking-tight md:text-[9rem]">
      <span class="italic">meridian</span>
    </h1>
    <p class="mt-8 max-w-xl font-[family-name:var(--font-display)] text-xl italic text-[color:var(--color-ink)]/80 dark:text-[color:var(--color-bone)]/80 md:text-2xl">
      {hero.title}
    </p>
    <p class="mt-5 max-w-lg text-sm leading-relaxed text-[color:var(--color-mist)] md:text-base">
      {hero.body}
    </p>

    <div id="notify" class="mt-12 w-full">
      <EmailCapture id="hero-capture" source="landing-hero" buttonLabel="Join the list" />
      <p class="mt-10 text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-mist)]">
        First release · limited lots · free UK shipping over £40
      </p>
    </div>

    <a href="#story" class="mt-20 inline-flex flex-col items-center gap-2 text-[10px] uppercase tracking-[0.32em] text-[color:var(--color-mist)] transition hover:text-[color:var(--color-copper)]">
      <span>Scroll</span>
      <svg class="h-4 w-4 animate-bounce" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M19 12l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <section id="story" class="relative z-10 border-t border-[color:var(--color-mist)]/20">
    <div class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-12 px-6 py-24 md:grid-cols-12 md:px-10 md:py-32">
      <div class="md:col-span-4">
        <p class="text-[10px] uppercase tracking-[0.42em] text-[color:var(--color-mist)]">Chapter 01</p>
        <h2 class="mt-4 font-[family-name:var(--font-display)] text-4xl font-light italic leading-tight md:text-5xl">
          {story.title}
        </h2>
      </div>
      <div class="md:col-span-7 md:col-start-6">
        <p class="font-[family-name:var(--font-display)] text-2xl font-light leading-relaxed text-[color:var(--color-ink)]/85 dark:text-[color:var(--color-bone)]/85 md:text-3xl">
          {story.body}
        </p>
        <div class="mt-10 flex items-center gap-6 text-xs uppercase tracking-[0.3em] text-[color:var(--color-mist)]">
          <span>— The Meridian team</span>
          <span class="h-px flex-1 bg-[color:var(--color-mist)]/30"></span>
          <span>Est. 2025</span>
        </div>
      </div>
    </div>
  </section>

  <section id="craft" class="relative z-10 border-t border-[color:var(--color-mist)]/20 bg-[color:var(--color-cream)]/40 dark:bg-[color:var(--color-espresso)]/40">
    <div class="mx-auto w-full max-w-7xl px-6 py-24 md:px-10 md:py-32">
      <div class="mb-16 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-[10px] uppercase tracking-[0.42em] text-[color:var(--color-mist)]">Chapter 02</p>
          <h2 class="mt-3 font-[family-name:var(--font-display)] text-4xl font-light italic leading-tight md:text-5xl">
            From origin to cup.
          </h2>
        </div>
        <p class="max-w-sm text-sm text-[color:var(--color-mist)]">
          Three commitments we refuse to compromise — the difference between a coffee you drink and one you remember.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-14">
        {pillars.map((p) => (
          <Pillar index={p.idx} title={p.title} body={p.body} />
        ))}
      </div>
    </div>
  </section>

  <section class="relative z-10 border-t border-[color:var(--color-mist)]/20">
    <div class="mx-auto w-full max-w-3xl px-6 py-24 text-center md:px-10 md:py-28">
      <p class="text-[10px] uppercase tracking-[0.42em] text-[color:var(--color-mist)]">Chapter 03</p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] text-4xl font-light italic leading-tight md:text-6xl">
        Be the first to taste it.
      </h2>
      <p class="mx-auto mt-6 max-w-md text-sm leading-relaxed text-[color:var(--color-mist)] md:text-base">
        We're opening the first release to a small list. Drop your email and we'll send a single note when the first bags ship — no spam, no marketing noise.
      </p>
      <div class="mt-10">
        <EmailCapture id="footer-capture" source="landing-footer" buttonLabel="Reserve your spot" />
      </div>
    </div>
  </section>

  <footer class="relative z-10 border-t border-[color:var(--color-mist)]/20">
    <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-6 py-10 text-xs uppercase tracking-[0.28em] text-[color:var(--color-mist)] md:flex-row md:items-center md:justify-between md:px-10">
      <p>© {new Date().getFullYear()} Meridian Coffee Roasters</p>
      <p class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--color-copper)]"></span>
        Roasting soon · London
      </p>
      <p>hello@meridian.coffee</p>
    </div>
  </footer>
</Base>
