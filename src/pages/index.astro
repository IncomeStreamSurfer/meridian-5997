---
import Base from "../layouts/Base.astro";
---
<Base title="Meridian — Coming Soon">
  <main class="relative z-10 flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <p class="mb-4 text-xs uppercase tracking-[0.35em] text-[color:var(--color-mist)] pulse-slow">
      🛠 Building Meridian
    </p>
    <h1 class="font-[family-name:var(--font-display)] text-5xl md:text-7xl font-light italic leading-none">
      meridian
    </h1>
    <p class="mt-6 max-w-md text-sm md:text-base text-[color:var(--color-mist)]">
      A specialty coffee roastery. Landing page assembling in real time.
    </p>
  </main>
</Base>
